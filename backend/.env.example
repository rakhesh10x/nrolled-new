# ============================================================
# HR Assistant - Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
#   cp .env.example .env
# NEVER commit .env to version control.
# ============================================================

# --- LLM Configuration (Oxlo.ai) ---
OXLO_API_KEY=your_oxlo_api_key_here
LLM_BASE_URL=https://api.oxlo.ai/v1
LLM_MODEL=deepseek-v3.2
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.7

# --- JWT Authentication ---
SECRET_KEY=change-this-to-a-random-secret-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Database ---
DATABASE_URL=sqlite:///./hr_assistant.db

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Retrieval ---
RETRIEVER_TYPE=keyword

# --- Logging ---
LOG_LEVEL=INFO
